# ─── DATOS PERSONALES / SECRETS (CRÍTICO) ────────────────────────────
# Cualquier .md en context/ se considera PRIVADO por defecto. Solo se
# permiten los *.template.md (versiones genéricas públicas) y los
# explícitamente marcados como exempt más abajo.
context/*.md
!context/*.template.md
!context/REQUISITOS-THEMEFOREST.md

# Memoria de Claude Code / agents — local-only, nunca al repo.
.claude/
CLAUDE.md
AGENTS.md
MEMORY.md
memory/
.cursor/
.windsurf/

# Notas internas pre-publicación. Si decides publicarlas como
# transparencia histórica, quita esta línea.
ANTES-DE-PUBLICAR.md

# Configs / state runtime con keys
~/.config/themeforge/keys.json
**/keys.json
**/.env
**/.env.*
!**/.env.example
**/credentials.json
**/.credentials.json
# licensing.json local-only por si pones la versión real (con tu URL
# de panel y tu github_org) en el repo dir por error. La versión real
# va a ~/.config/themeforge/licensing.json (fuera del repo).
**/licensing.json
!licensing_config.py

# Builds privados
builds/

# PyInstaller / build artefactos
build/
dist/
*.spec
icon.iconset/
assets/themeforge.icns
# AppImage build outputs
*.AppImage
ThemeForge.AppDir/
appimagetool-*.AppImage
pkgroot/
# .deb / .rpm outputs (built locally)
*.deb
*.rpm
# AUR PKGBUILD scratch dirs
packaging/aur/*/pkg/
packaging/aur/*/src/
packaging/aur/*/*.pkg.tar.zst
packaging/aur/*/*.tar.gz
out/


